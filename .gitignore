# ══════════════════════════════════════════════════════
# YeparDTEcore — .gitignore
# ══════════════════════════════════════════════════════

# ── Certificados y firmas digitales (NUNCA al repo) ──
*.p12
*.pfx
*.pem
*.key
*.crt
*.cer

# ── CAFs del SII (contienen firma RSA del SII) ───────
caf_certificacion/
*.caf

# ── XMLs generados / de prueba ────────────────────────
*.xml
# Excepción: si tienes XMLs de schema que SÍ deben subir, usa:
# !app/schemas/*.xml

# ── Bases de datos locales ────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Variables de entorno ──────────────────────────────
.env
.env.*
!.env.example

# ── Python ────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Entornos virtuales ────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Testing y coverage ────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDEs ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────
*.log
logs/

# ── Archivos temporales de desarrollo ─────────────────
README-cloudshell.txt
crear_landing.py
boleta_prueba.xml
CERTIFICACION_FINAL_YEPAR.xml
EnvioBOLETA_FINAL_FIRMADO.xml
